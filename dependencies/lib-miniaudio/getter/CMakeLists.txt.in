# \file dependencies/lib-miniaudio/getter/CMakeLists.txt.in
# Configured by @CMAKE_CURRENT_LIST_FILE@
#
# @ONLY variables:
#  * CMAKE_GENERATOR - which generator to use
#  * SRC_DIR - where to extract the archive
#  * BUILD_DIR - where the integrated sources are built

cmake_minimum_required(VERSION 3.18...3.25)

project(getter NONE)

include(ExternalProject)
externalproject_add(get-miniaudio
    # Need miniaudio>=0.11
    # This is version 0.11.25
    URL "https://github.com/mackron/miniaudio/archive/9634bedb5b5a2ca38c1ee7108a9358a4e233f14d.zip"
    URL_MD5 "409a4e72955529995bd35bc7e20c07a4"
    CMAKE_ARGS
        "-G@CMAKE_GENERATOR@"
        SOURCE_DIR          "@SRC_DIR@"
        BINARY_DIR          "@BUILD_DIR@"
        CONFIGURE_COMMAND   ""
        BUILD_COMMAND       ""
        INSTALL_COMMAND     ""
        TEST_COMMAND        ""
)
